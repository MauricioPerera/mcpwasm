{
  "name": "@rckflr/mcpwasm",
  "version": "0.3.1",
  "description": "Static MCP host: run untrusted MCP tool.js files sandboxed in QuickJS-wasm (Cloudflare Workers or Node), with explicit host capabilities (fetchOrigin, callInternal, extraCapabilities) and llms.txt executable-skills parsing.",
  "type": "module",
  "license": "MIT",
  "author": "Mauricio Perera <mauricio.perera@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauricioPerera/mcpwasm.git"
  },
  "homepage": "https://mauricioperera.github.io/mcpwasm/",
  "bugs": {
    "url": "https://github.com/MauricioPerera/mcpwasm/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quickjs",
    "wasm",
    "sandbox",
    "cloudflare-workers",
    "llms.txt",
    "skills",
    "static-mcp"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "index.mjs",
  "bin": {
    "mcpwasm": "bin/mcpwasm-local.mjs"
  },
  "exports": {
    ".": "./index.mjs",
    "./host": "./host.mjs",
    "./host-async": "./host-async.mjs",
    "./mcp-core": "./mcp-core.mjs",
    "./mcp-core-async": "./mcp-core-async.mjs",
    "./llmstxt-parse": "./llmstxt-parse.mjs",
    "./sigstore-attest": "./sigstore-attest.mjs",
    "./shim": "./shim.mjs"
  },
  "files": [
    "bin/mcpwasm-local.mjs",
    "index.mjs",
    "host.mjs",
    "host-async.mjs",
    "mcp-core.mjs",
    "mcp-core-async.mjs",
    "llmstxt-parse.mjs",
    "sigstore-attest.mjs",
    "shim.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "node build.mjs && node mf-test.mjs",
    "spike": "node build-spike.mjs && node mf-spike.mjs",
    "gateway": "node build-gateway.mjs && node mf-gateway.mjs",
    "gateway:offline": "node build-gateway.mjs && node mf-gateway.mjs --offline",
    "memspike": "node build-memsnapshot.mjs && node build-memspike.mjs && node mf-memspike.mjs",
    "local": "node test-local.mjs",
    "validate-publisher": "node scripts/validate-publisher.mjs"
  },
  "dependencies": {
    "@jitl/quickjs-wasmfile-release-asyncify": "^0.32.0",
    "quickjs-emscripten-core": "^0.32.0",
    "sigstore": "^5.0.0"
  },
  "peerDependencies": {
    "quickjs-emscripten": "^0.32.0"
  },
  "peerDependenciesMeta": {
    "quickjs-emscripten": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jitl/quickjs-wasmfile-release-sync": "^0.32.0",
    "@rckflr/minimemory": "^3.2.0",
    "esbuild": "^0.25.0",
    "miniflare": "^4.20260630.0",
    "quickjs-emscripten": "^0.32.0",
    "wrangler": "^4.106.0"
  }
}
